<div class="col-md-4">
    <div class="card">
        <div class="card-body">
            {% set isLarge = (widgetSize|default('small')) == 'large' %}
            <h5 class="card-title">Email Notifications</h5>
            {% if emailConfigured %}
                {% if latestMail %}
                    {% if unreadCount > 0 %}
                        <span class="badge-outline">{{ unreadCount }} unread</span>
                    {% else %}
                        <span class="badge-outline">Inbox clear</span>
                    {% endif %}
                    <h6 class="mt-1 mb-0" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;">Latest</h6>
                    <ul class="list-unstyled">
                        <li>
                            <strong class="event-summary" style="font-size: 14px; font-weight: 700;">{{ latestMail.subject }}</strong><br/>
                            {% if isLarge %}
                                <small class="event-summary muted" style="font-size: 13px;">From: {{ latestMail.from }}</small><br/>
                                <small class="mono muted" style="font-size: 12px;">{{ latestMail.date }}</small>
                            {% else %}
                                <small class="event-summary muted" style="font-size: 13px;">{{ latestMail.from }}</small>
                            {% endif %}
                        </li>
                    </ul>
                {% else %}
                    <p class="muted">No emails in the inbox.</p>
                {% endif %}
            {% else %}
                <p class="muted">No email settings configured.</p>
            {% endif %}
        </div>
    </div>
</div>
