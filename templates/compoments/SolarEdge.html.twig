<div class="col-md-4">
    <div class="card">
        <div class="card-body">
            {% set isLarge = (widgetSize|default('small')) == 'large' %}
            <h5 class="card-title">Solar Stats</h5>
            {% if solarData %}
                <div style="display: grid; gap: 4px;">
                    <div style="padding: 3px 0 4px; border-top: 1px solid #000; border-bottom: 2px solid #000;">
                        <div class="muted" style="font-size: 10px; text-transform: uppercase;">Current Power</div>
                        <div class="mono" style="font-weight: 800; font-size: 18px; line-height: 1;">
                            {% if solarData.overview.currentPower.power < 1 %}
                                {{ (solarData.overview.currentPower.power * 1000) | round(0) }} W
                            {% else %}
                                {{ solarData.overview.currentPower.power | round(2) }} kW
                            {% endif %}
                        </div>
                    </div>
                    <div style="font-size: 11px; line-height: 1.2;">
                        <div>Day <strong class="mono">{{ solarData.overview.lastDayData.energy | round(1) }}</strong> kWh</div>
                        <div>Month <strong class="mono">{{ solarData.overview.lastMonthData.energy | round(0) }}</strong> kWh</div>
                        {% if isLarge %}
                            <div>Year <strong class="mono">{{ solarData.overview.lastYearData.energy | round(0) }}</strong> kWh</div>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <p class="card-text muted">No data available.</p>
            {% endif %}
        </div>
    </div>
</div>
