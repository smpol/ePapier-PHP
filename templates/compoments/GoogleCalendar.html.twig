<div class="col-md-4">
    <div class="card">
        <div class="card-body">
            {% set isLarge = (widgetSize|default('small')) == 'large' %}
            <h5 class="card-title">Upcoming Events</h5>
            <ul class="list-unstyled">
                {% if events %}
                    {% for event in events|slice(0, isLarge ? 4 : 2) %}
                        <li>
                            <strong class="event-summary" style="font-size: 15px; font-weight: 700;">{{ event.summary }}</strong><br/>
                            <small class="mono muted" style="font-size: 14px; font-weight: 600;">{{ event.start | date('d-m-Y H:i') }}</small>
                        </li>
                        {% if not loop.last %}
                            <hr/>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <p class="muted">No upcoming events.</p>
                {% endif %}
            </ul>
        </div>
    </div>
</div>
