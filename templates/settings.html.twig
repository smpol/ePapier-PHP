{% extends 'base.html.twig' %}

{% block title %}Settings - ePapier{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3">
            <div class="dashboard-card sticky-top" style="top: 2rem;">
                <div class="card-header border-0 pb-0">
                    Settings
                </div>
                <div class="card-body">
                    <nav class="sidebar-nav">
                        <a href="javascript:void(0)" class="sidebar-link active" onclick="showContent('location-settings')" data-section="location-settings">
                            <i class="fas fa-map-marker-alt"></i> Location
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('solar-settings')" data-section="solar-settings">
                            <i class="fas fa-sun"></i> SolarEdge
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('email-settings')" data-section="email-settings">
                            <i class="fas fa-envelope"></i> Email
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('google-settings')" data-section="google-settings">
                            <i class="fab fa-google"></i> Google Calendar
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('spotify-settings')" data-section="spotify-settings">
                            <i class="fab fa-spotify"></i> Spotify
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('countdown-settings')" data-section="countdown-settings">
                            <i class="fas fa-clock"></i> Countdown
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('layout-settings')" data-section="layout-settings">
                            <i class="fas fa-th-large"></i> Layout
                        </a>
                        <a href="javascript:void(0)" class="sidebar-link" onclick="showContent('timezone-settings')" data-section="timezone-settings">
                            <i class="fas fa-globe"></i> Timezone
                        </a>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Content Area -->
        <div class="col-lg-9">
            <!-- Location Settings -->
            <div id="location-settings" class="settings-section dashboard-card active">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fas fa-map-marker-alt fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Location Settings</h4>
                    </div>
                </div>
                <div class="card-body">
                    <form method="POST" action="/set-location">
                        <div class="mb-4">
                            <label for="city" class="form-label-premium">City (optional)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                                <input type="text" class="form-control border-start-0" id="city" name="city" placeholder="Enter city name..." list="city-list" style="border-color: var(--border-color); padding: 0.625rem 0.75rem;">
                            </div>
                            <datalist id="city-list"></datalist>
                            <div class="form-text mt-2">Enter city name or use GPS for automatic detection.</div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label for="latitude" class="form-label-premium">Latitude</label>
                                <input type="text" class="form-control-premium bg-light" id="latitude" name="latitude" value="{% if location %} {{ location.lat }} {% endif %}" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="longitude" class="form-label-premium">Longitude</label>
                                <input type="text" class="form-control-premium bg-light" id="longitude" name="longitude" value="{% if location %} {{ location.lon }} {% endif %}" readonly>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button" onclick="getLocation()" class="btn-premium btn-premium-outline flex-grow-1 justify-content-center">
                                <i class="fas fa-crosshairs"></i> Get GPS Location
                            </button>
                            <button type="submit" class="btn-premium btn-premium-primary flex-grow-1 justify-content-center">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- SolarEdge Settings -->
            <div id="solar-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fas fa-sun fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">SolarEdge API</h4>
                    </div>
                </div>
                <div class="card-body">
                    {% if not solarEdgeSettings %}
                        <form method="POST" action="/solar-edge" class="animate-fade-in">
                            <div class="mb-3">
                                <label for="api_key" class="form-label-premium">API Key</label>
                                <input type="password" class="form-control-premium" id="api_key" name="api_key" required placeholder="Paste your API key here">
                            </div>
                            <div class="mb-4">
                                <label for="site_id" class="form-label-premium">Site ID</label>
                                <input type="text" class="form-control-premium" id="site_id" name="site_id" required placeholder="e.g. 1234567">
                            </div>
                            <button type="submit" class="btn-premium btn-premium-primary w-100 justify-content-center">
                                <i class="fas fa-link"></i> Connect SolarEdge
                            </button>
                        </form>
                    {% else %}
                        <div class="text-center py-4 animate-fade-in">
                            <div class="text-success mb-3"><i class="fas fa-check-circle fa-3x"></i></div>
                            <h5>SolarEdge Connected</h5>
                            <p class="text-muted">Your solar data is being fetched correctly.</p>
                            <form method="POST" action="{{ path('delete-solar-edge') }}">
                                <button type="submit" class="btn-premium btn-premium-danger mt-3">
                                    <i class="fas fa-unlink"></i> Disconnect Site
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Email Settings -->
            <div id="email-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fas fa-envelope fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Email Account</h4>
                    </div>
                </div>
                <div class="card-body">
                    {% if not emailSettings %}
                        <form method="POST" action="/email-settings" class="animate-fade-in">
                            <div class="row g-3 mb-3">
                                <div class="col-md-8">
                                    <label for="imap_server" class="form-label-premium">IMAP Server</label>
                                    <input type="text" class="form-control-premium" id="imap_server" name="imap_server" required placeholder="imap.gmail.com">
                                </div>
                                <div class="col-md-4">
                                    <label for="imap_port" class="form-label-premium">Port</label>
                                    <input type="number" class="form-control-premium" id="imap_port" name="imap_port" required value="993">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="imap_username" class="form-label-premium">Username / Email</label>
                                <input type="text" class="form-control-premium" id="imap_username" name="imap_username" required placeholder="user@example.com">
                            </div>
                            <div class="mb-4">
                                <label for="imap_password" class="form-label-premium">App Password</label>
                                <input type="password" class="form-control-premium" id="imap_password" name="imap_password" required>
                            </div>
                            <button type="submit" class="btn-premium btn-premium-primary w-100 justify-content-center">
                                <i class="fas fa-save"></i> Save Email Config
                            </button>
                        </form>
                    {% else %}
                        <div class="text-center py-4 animate-fade-in">
                            <div class="text-primary mb-3"><i class="fas fa-envelope-open-text fa-3x"></i></div>
                            <h5>Email Configured</h5>
                            <p class="text-muted">Fetching unread messages for your dashboard.</p>
                            <form action="{{ path('delete-email') }}" method="post">
                                <button type="submit" class="btn-premium btn-premium-danger mt-3">
                                    <i class="fas fa-trash"></i> Remove Account
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Google Calendar Settings -->
            <div id="google-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fab fa-google fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Google Calendar</h4>
                    </div>
                </div>
                <div class="card-body text-center py-5">
                    {% if not googleSettings %}
                        <p class="text-muted mb-4">Connect your Google account to sync calendars with your ePapier display.</p>
                        <a href="{{ path('google-login') }}" class="btn-premium btn-premium-primary">
                            <i class="fab fa-google me-2"></i> Connect Google Calendar
                        </a>
                    {% else %}
                        <div class="text-success mb-3"><i class="fas fa-calendar-check fa-3x"></i></div>
                        <h5>Calendar Sync Active</h5>
                        <p class="text-muted">Google Calendar events are being synchronized.</p>
                        <a href="{{ path('google-remove-calendar') }}" class="btn-premium btn-premium-danger mt-3">
                            <i class="fas fa-sign-out-alt"></i> Disconnect Google
                        </a>
                    {% endif %}
                </div>
            </div>

            <!-- Spotify Settings -->
            <div id="spotify-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fab fa-spotify fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Spotify Integration</h4>
                    </div>
                </div>
                <div class="card-body text-center py-5">
                    {% if not spotifySettings %}
                        <p class="text-muted mb-4">Display "Now Playing" information on your e-paper screen.</p>
                        <a href="{{ path('spotify-login') }}" class="btn-premium btn-premium-primary">
                            <i class="fab fa-spotify me-2"></i> Connect Spotify
                        </a>
                    {% else %}
                        <div class="text-success mb-3"><i class="fab fa-spotify fa-3x"></i></div>
                        <h5>Spotify Linked</h5>
                        <p class="text-muted">Music info will be displayed when playing.</p>
                        
                        <form method="POST" action="/save-spotify-settings" class="mt-4 mb-4 text-start">
                            <div class="p-3 border rounded-3 bg-light d-flex align-items-center" style="border-color: var(--border-color) !important;">
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" role="switch" id="fullScreenOnSecond" name="fullScreenOnSecond" {% if spotifySettings[0].fullScreenOnSecond %}checked{% endif %} style="cursor: pointer; transform: scale(1.3); margin-top: 0;">
                                </div>
                                <label class="form-check-label ms-3 mb-0" for="fullScreenOnSecond" style="cursor: pointer; width: 100%;">
                                    <strong class="d-block mb-1">Enable full screen on <code>&second=true</code> parameter</strong>
                                    <span class="form-text text-muted d-block" style="font-size: 0.85rem;">When enabled, the dashboard will switch to this full-screen player during active playback if the <code>&second=true</code> parameter is present.</span>
                                </label>
                            </div>
                            <div class="mt-3 text-end">
                                <button type="submit" class="btn-premium btn-premium-primary">
                                    <i class="fas fa-save"></i> Save Settings
                                </button>
                            </div>
                        </form>

                        <a href="{{ path('spotify-logout') }}" class="btn-premium btn-premium-danger mt-3">
                            <i class="fas fa-power-off"></i> Disconnect
                        </a>
                    {% endif %}
                </div>
            </div>

            <!-- Countdown Settings -->
            <div id="countdown-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fas fa-hourglass-half fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Countdowns</h4>
                    </div>
                </div>
                <div class="card-body">
                    {% if countDown %}
                        <h6 class="text-uppercase text-muted fw-bold small mb-3">Active Countdowns</h6>
                        <div class="row g-3 mb-4">
                            {% for countdown in countDown %}
                                <div class="col-12">
                                    <div class="p-3 border rounded-3 bg-light">
                                        <form action="{{ path('updateCountdown') }}" method="post" id="update_form_{{ countdown.id }}">
                                            <input type="hidden" name="countdown_id" value="{{ countdown.id }}">
                                    <div class="row g-2 align-items-center">
                                                <div class="col-md-5">
                                                    <input type="datetime-local" class="form-control-premium" name="countdown_date" value="{{ countdown.date|date('Y-m-d\\TH:i') }}" required>
                                                </div>
                                                <div class="col-md-4">
                                                    <input type="text" class="form-control-premium" name="countdown_title" value="{{ countdown.description }}" minlength="1" maxlength="18" required>
                                                </div>
                                                <div class="col-md-3 d-flex gap-2">
                                                    <button type="submit" class="btn btn-primary btn-sm rounded-0 flex-grow-1" style="background: var(--primary-color); border-color: var(--primary-color);">
                                                        <i class="fas fa-save"></i>
                                                    </button>
                                                    <button type="submit" form="delete_form_{{ countdown.id }}" class="btn btn-outline-danger btn-sm rounded-0">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                        <form action="{{ path('deleteCountdown') }}" method="post" id="delete_form_{{ countdown.id }}" class="d-none">
                                            <input type="hidden" name="countdown_id" value="{{ countdown.id }}">
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <hr class="my-4">
                    {% endif %}

                    <h6 class="text-uppercase text-muted fw-bold small mb-3">Add New Countdown</h6>
                    <form action="{{ path('setCountdown') }}" method="post">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label-premium">Target Date</label>
                                <input type="datetime-local" class="form-control-premium" name="countdown_date" required>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label-premium">Title / Event Name</label>
                                <input type="text" class="form-control-premium" name="countdown_title" placeholder="e.g. Birthday" maxlength="18" required>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn-premium btn-premium-primary w-100 justify-content-center">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Timezone Settings -->
            <div id="timezone-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fas fa-globe fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Timezone</h4>
                    </div>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('set-timezone') }}">
                        <div class="mb-4">
                            <label for="timezone" class="form-label-premium">Select your timezone</label>
                            <select class="form-select form-control-premium" id="timezone" name="timezone" required>
                                <option value="">Select...</option>
                                {% for timezone in timeZones %}
                                    <option value="{{ timezone }}" {% if selectedTimezone == timezone %}selected{% endif %}>
                                        {{ timezone|replace({'_': ' '}) }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <button type="submit" class="btn-premium btn-premium-primary w-100 justify-content-center">
                            <i class="fas fa-save"></i> Update Timezone
                        </button>
                    </form>
                </div>
            </div>

            <!-- Layout Settings -->
            <div id="layout-settings" class="settings-section dashboard-card">
                <div class="card-header border-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted">
                            <i class="fas fa-th-large fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5 font-heading">Dashboard Layout</h4>
                    </div>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('set-layout') }}">
                        <div id="dashboard-grid" class="row g-3 mb-4">
                            {% for i in 0..5 %}
                                <div class="col-md-6 col-xl-4">
                                    <div class="p-3 border rounded-0 bg-light h-100" style="border-color: var(--border-color) !important;">
                                        <div class="mb-3">
                                            <label class="form-label-premium small text-uppercase">Slot {{ i + 1 }}</label>
                                            <select class="form-select form-control-premium component-select-input" name="component{{ i + 1 }}" required>
                                                <option value="">Select component</option>
                                                {% for key, name in availableComponents %}
                                                    <option value="{{ key }}" {{ selectedComponents[i] == key ? 'selected' : '' }}>
                                                        {{ name }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                        <div>
                                            <label class="form-label-premium small text-uppercase">Backup / Rotate</label>
                                            <select class="form-select form-control-premium replacement-select-input" name="replacement{{ i + 1 }}">
                                                <option value="">No replacement</option>
                                                {% for key, name in availableComponents %}
                                                    <option value="{{ key }}" {{ replacementLayout[i] == key ? 'selected' : '' }}>
                                                        {{ name }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <div id="validation-message" class="alert alert-danger py-2 mb-3" style="display: none;">
                            <i class="fas fa-exclamation-triangle me-2"></i> All slots must be unique.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button" id="reset-layout" class="btn-premium btn-premium-outline flex-grow-1 justify-content-center">
                                <i class="fas fa-undo"></i> Reset Layout
                            </button>
                            <button type="submit" class="btn-premium btn-premium-primary flex-grow-1 justify-content-center">
                                <i class="fas fa-save"></i> Save Layout
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Navigation logic
    function showContent(sectionId) {
        // Toggle sections
        const sections = document.querySelectorAll(".settings-section");
        sections.forEach(sec => {
            sec.classList.remove("active");
            if (sec.id === sectionId) {
                sec.classList.add("active");
            }
        });

        // Toggle sidebar links
        const links = document.querySelectorAll(".sidebar-link");
        links.forEach(link => {
            link.classList.remove("active");
            if (link.getAttribute('data-section') === sectionId) {
                link.classList.add("active");
            }
        });

        // Update URL
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set("tab", sectionId);
        window.history.replaceState(null, "", newUrl);
    }

    // Geolocation logic
    function getLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(showPosition, showError);
        } else {
            alert("Geolocation is not supported by this browser.");
        }
    }

    function showPosition(position) {
        document.getElementById("latitude").value = position.coords.latitude;
        document.getElementById("longitude").value = position.coords.longitude;
    }

    function showError(error) {
        let msg = "An unknown error occurred.";
        switch (error.code) {
            case error.PERMISSION_DENIED: msg = "User denied the request for Geolocation."; break;
            case error.POSITION_UNAVAILABLE: msg = "Location information is unavailable."; break;
            case error.TIMEOUT: msg = "The request to get user location timed out."; break;
        }
        alert(msg);
    }

    // Layout validation logic
    document.addEventListener('DOMContentLoaded', function () {
        const dashboardGrid = document.getElementById('dashboard-grid');
        const resetLayoutBtn = document.getElementById('reset-layout');
        const validationMessage = document.getElementById('validation-message');

        const urlParams = new URLSearchParams(window.location.search);
        const section = urlParams.get("tab") || "location-settings";
        showContent(section);

        function updateSelectOptions() {
            const mainSelects = document.querySelectorAll('.component-select-input');
            const replacementSelects = document.querySelectorAll('.replacement-select-input');
            const selectedMainValues = Array.from(mainSelects).map(select => select.value).filter(val => val !== '');
            const selectedReplacementValues = Array.from(replacementSelects).map(select => select.value).filter(val => val !== '');

            mainSelects.forEach(select => {
                const currentValue = select.value;
                Array.from(select.options).forEach(opt => opt.disabled = false);
                selectedMainValues.forEach(value => {
                    if (value !== currentValue) {
                        const opt = select.querySelector(`option[value="${value}"]`);
                        if (opt) opt.disabled = true;
                    }
                });
            });

            replacementSelects.forEach(select => {
                const currentValue = select.value;
                Array.from(select.options).forEach(opt => opt.disabled = false);
                selectedMainValues.concat(selectedReplacementValues).forEach(value => {
                    if (value !== currentValue) {
                        const opt = select.querySelector(`option[value="${value}"]`);
                        if (opt) opt.disabled = true;
                    }
                });
            });
        }

        function validateForm() {
            const mainSelects = document.querySelectorAll('.component-select-input');
            const replacementSelects = document.querySelectorAll('.replacement-select-input');
            const selectedMainValues = Array.from(mainSelects).map(select => select.value);
            const selectedReplacementValues = Array.from(replacementSelects).map(select => select.value).filter(val => val !== '');

            const allMainSelected = selectedMainValues.every(val => val !== '');
            const uniqueMainValues = new Set(selectedMainValues);
            const allUniqueMain = uniqueMainValues.size === selectedMainValues.length;
            const noOverlap = !selectedReplacementValues.some(val => uniqueMainValues.has(val));

            if (!allMainSelected || !allUniqueMain || !noOverlap) {
                validationMessage.style.display = 'block';
                return false;
            } else {
                validationMessage.style.display = 'none';
                return true;
            }
        }

        updateSelectOptions();

        dashboardGrid.addEventListener('change', function (e) {
            if (e.target.classList.contains('component-select-input') || e.target.classList.contains('replacement-select-input')) {
                updateSelectOptions();
                validateForm();
            }
        });

        resetLayoutBtn.addEventListener('click', function () {
            if (confirm('Are you sure you want to reset the layout?')) {
                document.querySelectorAll('.component-select-input, .replacement-select-input').forEach(select => select.value = '');
                updateSelectOptions();
                validateForm();
            }
        });
    });

    // City Autocomplete Optimization
    let cities = [];
    const cityInput = document.getElementById('city');
    const cityList = document.getElementById('city-list');

    fetch('/json/cities.json')
        .then(res => res.json())
        .then(data => {
            cities = data;
            // Initial population - only first 100 cities to prevent freeze
            populateCityList("");
        })
        .catch(err => console.error("Error loading cities:", err));

    let searchTimeout;
    function populateCityList(filter) {
        cityList.innerHTML = "";
        if (filter.length < 2) return; // Don't search for very short strings

        const search = filter.toLowerCase();
        let count = 0;
        
        for (let i = 0; i < cities.length && count < 50; i++) {
            if (cities[i].name.toLowerCase().includes(search)) {
                const opt = document.createElement('option');
                opt.value = cities[i].name;
                cityList.appendChild(opt);
                count++;
            }
        }
    }

    cityInput.addEventListener('input', function() {
        const val = this.value;
        
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            populateCityList(val);

            // Auto-fill coordinates if exact match found
            const city = cities.find(c => c.name.toLowerCase() === val.toLowerCase());
            if (city) {
                const latInput = document.getElementById('latitude');
                const lonInput = document.getElementById('longitude');
                if (latInput) latInput.value = city.lat;
                if (lonInput) lonInput.value = city.lng;
            }
        }, 300); // 300ms debounce
    });
</script>
{% endblock %}
