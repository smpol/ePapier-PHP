<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ePapier Screen</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="/css/weather-icons.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap">
    <style>
        :root {
            --ink: #000;
            --paper: #fff;
            --line: #000;
            --gap: 8px;
            --radius: 10px;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            width: 800px;
            height: 480px;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        body {
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: var(--ink);
            background: var(--paper);
            -webkit-font-smoothing: none;
        }

        .screen-shell {
            height: 100%;
            width: 100%;
            padding: 8px;
            display: block;
            background: var(--paper);
        }

        .screen-grid {
            height: 100%;
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            grid-template-rows: repeat(4, minmax(0, 1fr));
            gap: var(--gap);
            min-height: 0;
        }

        .screen-slot {
            min-width: 0;
            min-height: 0;
        }

        .screen-slot--1 { grid-column: 1 / span 6; grid-row: 1 / span 2; }
        .screen-slot--2 { grid-column: 7 / span 6; grid-row: 1 / span 2; }
        .screen-slot--3 { grid-column: 1 / span 4; grid-row: 3 / span 2; }
        .screen-slot--4 { grid-column: 5 / span 4; grid-row: 3 / span 2; }
        .screen-slot--5 { grid-column: 9 / span 4; grid-row: 3 / span 2; }

        .screen-slot > .col-md-4 {
            width: 100%;
            margin: 0;
            padding: 0;
            height: 100%;
            max-width: none;
        }

        .screen-slot .card {
            border: 0;
            border-radius: 0;
            margin: 0;
            height: 100%;
            background: transparent;
            position: relative;
            overflow: hidden;
        }

        .screen-slot .card-body {
            height: 100%;
            padding: 8px 8px 6px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            gap: 4px;
            min-height: 0;
            overflow: hidden;
            border-top: 2px solid var(--line);
        }

        .screen-slot--1 .card-body,
        .screen-slot--2 .card-body {
            padding: 12px;
        }

        .screen-slot .card-title,
        .screen-slot h4.card-title,
        .screen-slot h5.card-title,
        .screen-slot h6.card-title {
            color: var(--ink);
            margin: 0 0 4px 0;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            line-height: 1.2;
            border-bottom: 2px solid var(--line);
            padding-bottom: 4px;
        }

        .screen-slot--1 .card-title,
        .screen-slot--2 .card-title {
            font-size: 13px;
        }

        .screen-slot .card-text,
        .screen-slot p,
        .screen-slot li,
        .screen-slot small,
        .screen-slot h4,
        .screen-slot h5,
        .screen-slot h6 {
            color: var(--ink);
        }

        .screen-slot p,
        .screen-slot h4,
        .screen-slot h5,
        .screen-slot h6 {
            margin-bottom: 2px;
        }

        .screen-slot .text-center {
            text-align: left !important;
        }

        .screen-slot .d-flex.justify-content-center {
            justify-content: flex-start !important;
        }

        .screen-slot .row {
            margin-left: -4px;
            margin-right: -4px;
        }

        .screen-slot .row > [class*='col-'] {
            padding-right: 4px;
            padding-left: 4px;
        }

        .screen-slot ul {
            margin: 0;
            padding: 0;
        }

        .screen-slot .list-unstyled li {
            padding: 2px 0;
        }

        .screen-slot hr {
            border: 0;
            border-top: 1px solid #000;
            margin: 3px 0;
            opacity: 1;
        }

        .event-summary {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: inline-block;
            max-width: 100%;
        }

        .weather-icon {
            font-size: 24px;
            color: var(--ink);
        }

        .screen-slot canvas {
            image-rendering: pixelated;
        }

        .muted {
            opacity: 1;
        }

        .mono {
            font-family: 'Inter', sans-serif;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.02em;
        }

        .badge-outline {
            border: 0;
            border-bottom: 1px solid var(--line);
            border-radius: 0;
            padding: 0 0 1px 0;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            display: inline-block;
            line-height: 1.1;
            width: fit-content;
        }
    </style>
</head>
<body>
<div class="screen-shell">
    <div class="screen-grid">
        {% for component in layout|slice(0, 5) %}
            {% set widgetSize = loop.index <= 2 ? 'large' : 'small' %}
            <div class="screen-slot screen-slot--{{ loop.index }}">
                {% include 'compoments/' ~ component ~ '.html.twig' with ({
                    'CurrentWeather': {'weather': weather, 'timeZone': timeZone},
                    'Forecast': {'weather': weather},
                    'Spotify': {'spotifyNowPlaying': spotifyNowPlaying},
                    'GoogleCalendar': {'events': events},
                    'Emails': {'emailConfigured': emailConfigured, 'latestMail': latestMail, 'unreadCount': unreadCount},
                    'SolarEdge': {'solarData': solarData},
                    'SolarEdgeChart': {'weeklyProductionData': weeklyProductionData},
                    'AirQuality': {'airQuality': airQuality},
                    'Countdown': {'countdown': countdown},
                    'Clock': {'timeZone': timeZone}
                }[component])|merge({
                    'widgetSize': widgetSize,
                    'widgetSlot': loop.index
                }) %}
            </div>
        {% endfor %}
    </div>
</div>
<script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
