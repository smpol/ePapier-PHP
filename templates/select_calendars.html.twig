{% extends 'base.html.twig' %}

{% block title %}Select Calendars - ePapier{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 animate-fade-in">
            <div class="dashboard-card shadow-lg">
                <div class="card-header bg-white border-0 pb-0">
                    <div class="d-flex align-items-center mb-3">
                        <div class="p-2 rounded-3 me-3 text-slate-400">
                            <i class="fab fa-google fa-lg"></i>
                        </div>
                        <h4 class="mb-0 fs-5">Select Google Calendars</h4>
                    </div>
                    <p class="text-muted small">Choose the calendars you want to synchronize with your ePapier display.</p>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('google-save-calendar') }}">
                        <div class="list-group list-group-flush mb-4 border rounded-3 overflow-hidden">
                            {% for calendar in calendars %}
                                <label class="list-group-item list-group-item-action d-flex align-items-center py-3 border-bottom cursor-pointer">
                                    <input type="checkbox" name="calendars[]" value="{{ calendar.id }}" class="form-check-input me-3" style="width: 1.25rem; height: 1.25rem;">
                                    <div>
                                        <div class="fw-bold text-main">{{ calendar.summary }}</div>
                                        <div class="text-muted small">Google Calendar ID: {{ calendar.id }}</div>
                                    </div>
                                </label>
                            {% else %}
                                <div class="list-group-item text-center py-5">
                                    <i class="fas fa-calendar-times fa-3x text-light mb-3"></i>
                                    <p class="text-muted">No calendars available to sync.</p>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn-premium btn-premium-primary justify-content-center py-3">
                                <i class="fas fa-sync-alt me-2"></i> Sync Selected Calendars
                            </button>
                            <a href="/settings?tab=google-settings" class="btn-premium btn-premium-outline justify-content-center">
                                <i class="fas fa-arrow-left me-2"></i> Back to Settings
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
